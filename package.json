{
  "license": "ISC",
  "scripts": {
    "fork": "ts-node --skip-project tests/utils/account-fork.ts",
    "test": "ts-mocha -p ./tsconfig.json -t 1000000 tests/solana_arbitrage_program.ts",
    "init": "ts-node --skip-project scripts/init-program.ts",
    "init:dry": "DRY_RUN=true ts-node --skip-project scripts/init-program.ts",
    "arb": "ts-node --skip-project scripts/execute-arb.ts",
    "arb:dry": "DRY_RUN=true ts-node --skip-project scripts/execute-arb.ts",
    "arb:reverse": "ROUTE=meteora-pump ts-node --skip-project scripts/execute-arb.ts",
    "arb:reverse:dry": "DRY_RUN=true ROUTE=meteora-pump ts-node --skip-project scripts/execute-arb.ts",
    "swap:pump:buy": "ts-node --skip-project scripts/swap-pumpfun.ts",
    "swap:pump:sell": "DIRECTION=sell ts-node --skip-project scripts/swap-pumpfun.ts",
    "swap:pump:buy:dry": "DRY_RUN=true ts-node --skip-project scripts/swap-pumpfun.ts",
    "swap:pump:sell:dry": "DRY_RUN=true DIRECTION=sell ts-node --skip-project scripts/swap-pumpfun.ts",
    "swap:meteora:buy": "ts-node --skip-project scripts/swap-meteora.ts",
    "swap:meteora:sell": "DIRECTION=sell ts-node --skip-project scripts/swap-meteora.ts",
    "swap:meteora:buy:dry": "DRY_RUN=true ts-node --skip-project scripts/swap-meteora.ts",
    "swap:meteora:sell:dry": "DRY_RUN=true DIRECTION=sell ts-node --skip-project scripts/swap-meteora.ts",
    "lint:fix": "prettier */*.js \"*/**/*{.js,.ts}\" -w",
    "lint": "prettier */*.js \"*/**/*{.js,.ts}\" --check"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "anchor-bankrun": "^0.5.0",
    "solana-bankrun": "^0.4.0"
  },
  "devDependencies": {
    "@types/bn.js": "^5.1.0",
    "@types/chai": "^4.3.0",
    "@types/mocha": "^9.0.0",
    "chai": "^4.3.4",
    "mocha": "^9.0.3",
    "prettier": "^2.6.2",
    "ts-mocha": "^10.0.0",
    "typescript": "^5.7.3"
  }
}
